[Unit]
Description=acp-stack self-update
Documentation=https://github.com/atrium-cloud/acp-stack/blob/main/docs/deploy/systemd.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=HOME=@HOME_DIR@
EnvironmentFile=-/etc/acp-stack/environment
ExecStart=/usr/local/bin/acps update install --latest --auto --restart-service acp-stack.service
TimeoutStartSec=10min
StandardOutput=journal
StandardError=journal
